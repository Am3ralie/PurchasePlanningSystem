@{
    Layout = "_Layout";
    ViewData["Title"] = "Детали заявки";
    var request = ViewBag.Request as System.Data.DataRow;
    var items = ViewBag.Items as System.Data.DataTable;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Заявка @request?["Number"]</h2>
        <a href="/PurchaseRequests" class="btn btn-outline-secondary">← Назад</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p>
                        <strong>Статус:</strong>
                        <span class="badge @(request?["Status"]?.ToString() == "Draft" ? "bg-secondary" : "bg-success")">
                            @request?["Status"]
                        </span>
                    </p>
                    <p><strong>Создал:</strong> @request?["CreatedByName"]</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Дата создания:</strong> @Convert.ToDateTime(request?["Date"]).ToString("dd.MM.yyyy HH:mm")</p>
                    <p><strong>Комментарии:</strong> @(string.IsNullOrEmpty(request?["Comments"]?.ToString()) ? "нет" : request?["Comments"])</p>
                </div>
            </div>
        </div>
    </div>

    <h4>Строки заявки</h4>
    @if (items != null && items.Rows.Count > 0)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Продукт</th>
                    <th>Количество</th>
                    <th>Ед. изм.</th>
                    <th>Требуемая дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (System.Data.DataRow row in items.Rows)
                {
                    <tr>
                        <td>@row["ProductName"]</td>
                        <td>@row["Quantity"]</td>
                        <td>@row["Unit"]</td>
                        <td>@Convert.ToDateTime(row["RequiredDate"]).ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">Нет строк в заявке</div>
    }

    <!-- ОДНА КНОПКА ДЕЙСТВИЯ ВНИЗУ -->
    <div class="mt-4 d-flex justify-content-between">
        <div>
            @if (request?["Status"]?.ToString() == "Draft")
            {
                <!-- Добавляем кнопки редактирования/удаления -->
                var currentUserId = Context.Session.GetString("UserId");
                var currentUserRole = Context.Session.GetString("UserRole");
                var isOwner = request?["CreatedByUserId"]?.ToString() == currentUserId;
                var canEdit = isOwner || currentUserRole == "Admin";

                if (canEdit)
                {
                    <a href="/PurchaseRequests/Edit/@request?["Id"]" class="btn btn-primary">✏️ Редактировать</a>
                    <a href="/PurchaseRequests/Delete/@request?["Id"]"
                       class="btn btn-danger"
                       onclick="return confirm('Удалить заявку @request?["Number"]?')">🗑️ Удалить</a>
                }
            }
        </div>
