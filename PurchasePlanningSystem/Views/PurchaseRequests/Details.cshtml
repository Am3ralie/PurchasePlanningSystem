@{
    Layout = "_Layout";
    ViewData["Title"] = "Детали заявки";
}

<div class="container mt-4">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Заявка @ViewBag.Number</h2>
        <a href="/PurchaseRequests" class="btn btn-outline-secondary">← Назад</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p>
                        <strong>Статус:</strong>
                        <span class="badge @(ViewBag.Status == "Draft" ? "bg-secondary" : "bg-success")">
                            @ViewBag.Status
                        </span>
                    </p>
                    <p><strong>Создал:</strong> @ViewBag.CreatedByName</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Дата создания:</strong> @ViewBag.CreatedDate</p>
                    <p><strong>Комментарии:</strong> @ViewBag.Comments</p>
                </div>
            </div>
        </div>
    </div>

    <h4>Строки заявки</h4>

    @if (ViewBag.HasItems)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Продукт</th>
                    <th>Количество</th>
                    <th>Ед. изм.</th>
                    <th>Требуемая дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Quantity</td>
                        <td>@item.Unit</td>
                        <td>@item.RequiredDate</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">Нет строк в заявке</div>
    }

    <!-- КНОПКИ -->
    <div class="mt-4">
        @if (ViewBag.ShowEditButtons)
        {
            <a href="/PurchaseRequests/Edit/@ViewBag.Id" class="btn btn-primary">✏️ Редактировать</a>

            <form method="post" action="/PurchaseRequests/Delete/@ViewBag.Id" style="display: inline;">
                <button type="submit" class="btn btn-danger"
                        onclick="return confirm('Удалить заявку @ViewBag.Number?')">
                    🗑️ Удалить
                </button>
            </form>

            <form method="post" action="/PurchaseRequests/UpdateStatus/@ViewBag.Id" style="display: inline;">
                <input type="hidden" name="newStatus" value="Completed" />
                <button type="submit" class="btn btn-success">✅ Завершить заявку</button>
            </form>
        }

        @if (ViewBag.ShowReopenButton)
        {
            <form method="post" action="/PurchaseRequests/UpdateStatus/@ViewBag.Id" style="display: inline;">
                <input type="hidden" name="newStatus" value="Draft" />
                <button type="submit" class="btn btn-warning">↩️ Вернуть в работу</button>
            </form>
        }

        <a href="/PurchaseRequests" class="btn btn-secondary">Вернуться к списку</a>
    </div>
</div>