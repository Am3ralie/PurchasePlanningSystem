@{
    Layout = "_Layout";
    ViewData["Title"] = "Заявки на закупку";
}

<h2>Заявки на закупку</h2>

@if (ViewBag.Requests != null && ViewBag.Requests.Rows.Count > 0)
{
    <table class="table table-hover">
        <thead><tr><th>Номер</th><th>Дата</th><th>Статус</th><th>Создал</th><th>Действия</th></tr></thead>
        <tbody>
            @foreach (System.Data.DataRow row in ViewBag.Requests.Rows)
            {
                <tr>
                    <td>@row["Number"]</td>
                    <td>@Convert.ToDateTime(row["Date"]).ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @{
                            var status = row["Status"].ToString();
                            var badgeClass = status == "Draft" ? "bg-secondary" :
                            status == "Processed" ? "bg-success" : "bg-warning";
                        }
                        <span class="badge @badgeClass">@status</span>
                    </td>
                    <td>@row["CreatedBy"]</td>
                    <td>
                        <a href="/PurchaseRequests/Details/@row["Id"]" class="btn btn-sm btn-info">Просмотр</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        <h5>Нет заявок. Создайте первую!</h5>
    </div>
}

<div class="mt-3">
    <a href="/PurchaseRequests/Create" class="btn btn-success">➕ Создать новую заявку</a>
</div>