@{
    Layout = "_Layout";
    ViewData["Title"] = "Заявки на закупку";
}
@using System.Data

<div class="container mt-4">
    <h2>Заявки на закупку</h2>

    @if (ViewBag.Requests != null && ((DataTable)ViewBag.Requests).Rows.Count > 0)
    {
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Номер</th>
                    <th>Дата</th>
                    <th>Статус</th>
                    <th>Создал</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (System.Data.DataRow row in ((DataTable)ViewBag.Requests).Rows)
                {
                    // Простые переменные
                    var status = row["Status"].ToString();
                    var createdByUserId = row["CreatedByUserId"].ToString();
                    var currentUserId = ViewBag.UserId;
                    var currentUserRole = ViewBag.UserRole;

                    var isOwner = createdByUserId == currentUserId;
                    var canEdit = false;

                    // Тупая логика: админ может всё, пользователь — только свои черновики
                    if (currentUserRole == "Admin")
                    {
                        canEdit = true;
                    }
                    else
                    {
                        canEdit = (status == "Draft" && isOwner);
                    }

                    <tr>
                        <td>@row["Number"]</td>
                        <td>@Convert.ToDateTime(row["Date"]).ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @{
                                var badgeClass = "bg-secondary";
                                if (status == "Completed") badgeClass = "bg-success";
                                else if (status == "Processed") badgeClass = "bg-info";
                            }
                            <span class="badge @badgeClass">@status</span>
                        </td>
                        <td>@row["CreatedBy"]</td>
                        <td>
                            <a href="/PurchaseRequests/Details/@row["Id"]" class="btn btn-sm btn-info">👁️ Просмотр</a>

                            @if (canEdit)
                            {
                                <a href="/PurchaseRequests/Edit/@row["Id"]" class="btn btn-sm btn-warning">✏️</a>

                                <form method="post" action="/PurchaseRequests/Delete/@row["Id"]" style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Удалить заявку @row["Number"]?')">
                                        🗑️
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <h5>Нет заявок. Создайте первую!</h5>
        </div>
    }

    <div class="mt-3">
        <a href="/PurchaseRequests/Create" class="btn btn-success">➕ Создать новую заявку</a>
    </div>
</div>