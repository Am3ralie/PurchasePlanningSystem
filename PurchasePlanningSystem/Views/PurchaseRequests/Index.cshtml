@{
    Layout = "_Layout";
    ViewData["Title"] = "Заявки на закупку";
}
@using System.Data

<div class="container mt-4">
    <h2>Заявки на закупку</h2>

    @if (ViewBag.Requests != null && ((DataTable)ViewBag.Requests).Rows.Count > 0)
    {
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Номер</th>
                    <th>Дата</th>
                    <th>Статус</th>
                    <th>Создал</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var requests = (DataTable)ViewBag.Requests;
                    var currentUserId = Context.Session.GetString("UserId");
                    var currentUserRole = Context.Session.GetString("UserRole");
                }

                @foreach (DataRow row in requests.Rows)
                {
                    // Безопасное получение данных
                    var status = row["Status"]?.ToString() ?? "";
                    var createdByUserIdValue = row["CreatedByUserId"];
                    var createdByUserId = (createdByUserIdValue != DBNull.Value) ? createdByUserIdValue.ToString() : "";

                    var isOwner = createdByUserId == currentUserId;
                    var canEdit = false;
                    if (currentUserRole == "Admin")
                    {
                        canEdit = true; // Админ может редактировать/удалять любую заявку
                    }
                    else
                    {
                        canEdit = (status == "Draft" && isOwner); // Обычный пользователь — только свои черновики
                    }

                    <tr>
                        <td>@row["Number"]</td>
                        <td>@Convert.ToDateTime(row["Date"]).ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @{
                                var badgeClass = status == "Draft" ? "bg-secondary" :
                                status == "Completed" ? "bg-success" :
                                status == "Processed" ? "bg-info" : "bg-warning";
                            }
                            <span class="badge @badgeClass">@status</span>
                        </td>
                        <td>@row["CreatedBy"]</td>
                        <td>
                            <a href="/PurchaseRequests/Details/@row["Id"]" class="btn btn-sm btn-info">👁️ Просмотр</a>

                            @if (canEdit)
                            {
                                <a href="/PurchaseRequests/Edit/@row["Id"]" class="btn btn-sm btn-warning">✏️</a>
                                <a href="/PurchaseRequests/Delete/@row["Id"]"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Удалить заявку @row["Number"]?')">🗑️</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <h5>Нет заявок. Создайте первую!</h5>
        </div>
    }

    <div class="mt-3">
        <a href="/PurchaseRequests/Create" class="btn btn-success">➕ Создать новую заявку</a>
    </div>
</div>