@model List<PurchasePlanningSystem.Models.PurchaseRequestViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Заявки на закупку";
}

<h2>Заявки на закупку</h2>

@if (Model != null && Model.Any())
{
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Номер</th>
                <th>Дата</th>
                <th>Статус</th>
                <th>Создал</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.Number</td>
                    <td>@request.Date.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <span class="badge @(request.Status == "Draft" ? "bg-secondary" :
                                                                        request.Status == "Approved" ? "bg-success" :
                                                                        "bg-warning")">
                    @request.Status
                </span>
            </td>
            <td>@request.CreatedBy</td>
            <td>
                <a href="@Url.Action("Details", new { id = request.Id })"
                   class="btn btn-sm btn-outline-info">Просмотр</a>

                @if (request.Status == "Draft")
                        {
                            <a href="@Url.Action("CreateOrder", new { requestId = request.Id })"
                               class="btn btn-sm btn-outline-warning">Формировать заказ</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        <h5>Нет заявок. Создайте первую!</h5>
    </div>
}

<div class="mt-3">
    <a asp-action="Create" class="btn btn-success">➕ Создать новую заявку</a>
</div>