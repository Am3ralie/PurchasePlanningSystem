@{
    ViewData["Title"] = "Создание заявки";
}
<h2>Создание заявки на закупку</h2>

<form method="post">
    <div class="form-group">
        <label>Выберите продукт:</label>
        <select name="productId" class="form-control" required>
            <option value="">-- Выберите продукт --</option>
            @if (ViewBag.Products != null)
            {
                foreach (System.Data.DataRow row in ViewBag.Products.Rows)
                {
                    <option value="@row["Id"]">@row["Name"] (@row["Unit"])</option>
                }
            }
        </select>
    </div>

    <div class="form-group">
        <label>Количество:</label>
        <input type="number" name="quantity" step="0.001" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Требуемая дата:</label>
        <input type="date" name="requiredDate" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary">Создать заявку</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>