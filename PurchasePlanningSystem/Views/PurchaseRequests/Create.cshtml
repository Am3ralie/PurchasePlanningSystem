@{
    Layout = "_Layout";
    ViewData["Title"] = "Создание заявки";
}
<h2>Создание заявки на закупку</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form method="post" action="/PurchaseRequests/Create">
    <div class="form-group mb-3">
        <label>Продукт:</label>
        <select name="productIds" class="form-control" required>
            <option value="">-- Выберите продукт --</option>
            @if (ViewBag.Products != null)
            {
                foreach (System.Data.DataRow row in ViewBag.Products.Rows)
                {
                    <option value="@row["Id"]">@row["Name"] (@row["Unit"])</option>
                }
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Количество:</label>
        <input type="number" name="quantities" step="0.001" class="form-control" value="1" required />
    </div>

    <div class="form-group mb-3">
        <label>Требуемая дата:</label>
        <input type="date" name="dates" class="form-control"
               value="@DateTime.Now.AddDays(3).ToString("yyyy-MM-dd")" required />
    </div>

    <button type="submit" class="btn btn-primary">Создать заявку</button>
    <a href="/PurchaseRequests" class="btn btn-secondary">Отмена</a>
</form>