<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Система планирования закупок</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { padding-top: 20px; background-color: #f8f9fa; }
        .container { max-width: 1200px; }
        .navbar { margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">📦 Закупки</a>
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a class="btn btn-sm btn-outline-dark ms-2" href="/Admin/Users">👑 Админка</a>
                }
                <div class="navbar-nav ms-auto">
                    @if (Context.Session.GetString("UserId") != null)
                    {
                        <span class="navbar-text me-3">
                            Вы вошли как: <strong>@Context.Session.GetString("UserRole")</strong>
                        </span>
                        <a class="btn btn-sm btn-outline-danger" href="/Auth/Logout">Выйти</a>
                    }
                </div>
            </div>
        </nav>

        <main>
            @RenderBody()
        </main>

        <footer class="mt-5 pt-3 border-top text-muted">
            <div class="text-center">
                <small>Система планирования закупок &copy; @DateTime.Now.Year</small>
            </div>
        </footer>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>